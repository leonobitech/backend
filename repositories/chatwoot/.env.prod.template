######################################
# 🔐 Claves esenciales
######################################
SECRET_KEY_BASE=  # 🔑 Generá con: `openssl rand -hex 64`
FRONTEND_URL=https://chat.leonobitech.com
ENABLE_ACCOUNT_SIGNUP=false
FORCE_SSL=true
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
ACTIVE_STORAGE_SERVICE=local

######################################
# 💾 Base de datos PostgreSQL
######################################
POSTGRES_HOST=postgres_chatwoot
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=

######################################
# 🚦 Redis
######################################
REDIS_URL=redis://redis_chatwoot:6379
REDIS_PASSWORD=

######################################
# 📬 SMTP - Email saliente (opcional)
######################################
MAILER_SENDER_EMAIL=Chatwoot <noreply@leonobitech.com>
SMTP_DOMAIN=leonobitech.com
SMTP_ADDRESS=smtp.leonobitech.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

######################################
# 📥 Email entrante (opcional)
######################################
MAILER_INBOUND_EMAIL_DOMAIN=
RAILS_INBOUND_EMAIL_SERVICE=
RAILS_INBOUND_EMAIL_PASSWORD=

######################################
# 📦 Almacenamiento en la nube (opcional)
######################################
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
DIRECT_UPLOADS_ENABLED=false

######################################
# ⚙️ Logging & rendimiento
######################################
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
LOG_SIZE=500
# SIDEKIQ_CONCURRENCY=10

######################################
# 🧠 OpenAI (opcional)
######################################
OPENAI_API_KEY=

######################################
# 📲 Notificaciones push (si usás apps)
######################################
ENABLE_PUSH_RELAY_SERVER=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
FCM_SERVER_KEY=

######################################
# 💳 Stripe (opcional)
######################################
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

######################################
# 🌐 Integraciones sociales (opcional)
######################################
FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_APP_ID=

IG_VERIFY_TOKEN=

TWITTER_APP_ID=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ENVIRONMENT=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=

AZURE_APP_ID=
AZURE_APP_SECRET=

######################################
# 📊 Observabilidad (opcional)
######################################
SENTRY_DSN=
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SECRET_TOKEN=
SCOUT_KEY=
SCOUT_NAME=
SCOUT_MONITOR=true
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APPLICATION_LOGGING_ENABLED=false
DD_TRACE_AGENT_URL=

######################################
# 🛡️ Seguridad avanzada (opcional)
######################################
ENABLE_RACK_ATTACK=true
RACK_ATTACK_LIMIT=300
RACK_ATTACK_ALLOWED_IPS=127.0.0.1,::1

######################################
# 🧪 Dev/debug/local (opcional)
######################################
LETTER_OPENER=false
CW_API_ONLY_SERVER=false
