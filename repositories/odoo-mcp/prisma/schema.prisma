// Prisma schema for odoo-mcp authentication system
// MongoDB version - Production-ready user management system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User accounts with Odoo credentials
model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?

  // Odoo integration credentials (encrypted)
  odooUrl      String?  @map("odoo_url")
  odooDb       String?  @map("odoo_db")
  odooUsername String?  @map("odoo_username")
  odooApiKey   String?  @map("odoo_api_key") // Encrypted in application layer

  // Account status
  isActive     Boolean  @default(true) @map("is_active")
  emailVerified Boolean @default(false) @map("email_verified")

  // Metadata
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  // Relations
  sessions     Session[]
  consents     OAuthConsent[]
  securityEvents SecurityEvent[]

  @@map("users")
}

// Active sessions with device fingerprinting
model Session {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @map("user_id") @db.ObjectId

  // Device fingerprinting for security
  deviceFingerprint String   @map("device_fingerprint") // SHA-256 hash of IP + UserAgent + userId
  ipAddress         String   @map("ip_address")
  userAgent         String   @map("user_agent")

  // Session lifecycle
  expiresAt         DateTime @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  lastUsedAt        DateTime @default(now()) @map("last_used_at")

  // Security flags
  isRevoked         Boolean  @default(false) @map("is_revoked")
  revokedAt         DateTime? @map("revoked_at")
  revokeReason      String?  @map("revoke_reason")

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// OAuth consent tracking (GDPR compliant)
model OAuthConsent {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @map("user_id") @db.ObjectId
  clientId    String    @map("client_id")

  // Granted scopes (space-separated)
  scopes      String

  // Consent lifecycle
  grantedAt   DateTime  @default(now()) @map("granted_at")
  expiresAt   DateTime? @map("expires_at") // null = never expires
  revokedAt   DateTime? @map("revoked_at")

  // Audit trail
  ipAddress   String    @map("ip_address")
  userAgent   String    @map("user_agent")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@map("oauth_consents")
}

// Security event logging for audit and anomaly detection
model SecurityEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @map("user_id") @db.ObjectId // nullable for pre-auth events

  // Event classification
  eventType   String   @map("event_type") // login.success, login.failed, oauth.consent.granted, etc.
  severity    String   // info, warning, critical

  // Event details
  ipAddress   String   @map("ip_address")
  userAgent   String   @map("user_agent")
  metadata    String?  // JSON string with additional context

  // Timestamp
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("security_events")
}
