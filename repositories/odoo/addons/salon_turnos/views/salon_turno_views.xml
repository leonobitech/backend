<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de Lista -->
    <record id="salon_turno_view_list" model="ir.ui.view">
        <field name="name">salon.turno.list</field>
        <field name="model">salon.turno</field>
        <field name="arch" type="xml">
            <list string="Turnos" decoration-danger="estado == 'cancelado'" decoration-success="estado == 'confirmado'" decoration-muted="estado == 'completado'" decoration-warning="estado == 'pendiente_pago'">
                <field name="fecha_hora"/>
                <field name="clienta"/>
                <field name="telefono"/>
                <field name="trabajadora"/>
                <field name="servicio"/>
                <field name="duracion"/>
                <field name="precio"/>
                <field name="sena"/>
                <field name="sena_pagada"/>
                <field name="estado" widget="badge" decoration-danger="estado == 'cancelado'" decoration-success="estado == 'confirmado'" decoration-info="estado == 'completado'" decoration-warning="estado == 'pendiente_pago'"/>
            </list>
        </field>
    </record>

    <!-- Vista de Formulario -->
    <record id="salon_turno_view_form" model="ir.ui.view">
        <field name="name">salon.turno.form</field>
        <field name="model">salon.turno</field>
        <field name="arch" type="xml">
            <form string="Turno">
                <header>
                    <button name="action_generar_link_pago" type="object" string="Generar Link de Pago" class="btn-primary" invisible="link_pago or estado in ['completado', 'cancelado']"/>
                    <button name="action_confirmar_pago_manual" type="object" string="Confirmar Pago Manual" class="btn-secondary" invisible="sena_pagada or estado in ['completado', 'cancelado']"/>
                    <button name="action_completar" type="object" string="Completar" class="btn-success" invisible="estado != 'confirmado'"/>
                    <button name="action_cancelar" type="object" string="Cancelar" class="btn-danger" invisible="estado in ['completado', 'cancelado']"/>
                    <button name="action_reabrir" type="object" string="Reabrir" invisible="estado != 'cancelado'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="pendiente_pago,confirmado,completado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="clienta" placeholder="Nombre de la clienta"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos de la Clienta">
                            <field name="telefono" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                        <group string="Servicio">
                            <field name="trabajadora"/>
                            <field name="servicio"/>
                            <field name="servicio_detalle"/>
                        </group>
                    </group>
                    <group>
                        <group string="Fecha y Hora">
                            <field name="fecha_hora"/>
                            <field name="duracion"/>
                            <field name="fecha_fin"/>
                        </group>
                        <group string="Pago">
                            <field name="precio"/>
                            <field name="sena"/>
                            <field name="sena_pagada"/>
                            <field name="monto_restante"/>
                        </group>
                    </group>
                    <group string="Servicio Pendiente de Pago" invisible="not pending_changes">
                        <field name="pending_changes" readonly="1" widget="text"/>
                        <field name="monto_pago_pendiente"/>
                    </group>
                    <notebook>
                        <page string="Mercado Pago" invisible="not link_pago">
                            <group>
                                <group>
                                    <field name="link_pago" widget="url"/>
                                    <field name="mp_preference_id"/>
                                    <field name="mp_payment_id"/>
                                </group>
                                <group>
                                    <field name="total_pagado"/>
                                    <field name="cantidad_pagos"/>
                                </group>
                            </group>
                        </page>
                        <page string="Historial de Pagos" invisible="cantidad_pagos == 0">
                            <field name="pago_ids" readonly="1">
                                <list>
                                    <field name="fecha"/>
                                    <field name="tipo"/>
                                    <field name="monto"/>
                                    <field name="estado" widget="badge" decoration-success="estado == 'approved'" decoration-warning="estado == 'pending'" decoration-danger="estado in ['rejected', 'cancelled']"/>
                                    <field name="mp_payment_id"/>
                                    <field name="descripcion"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas">
                            <field name="notas" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista de Calendario -->
    <record id="salon_turno_view_calendar" model="ir.ui.view">
        <field name="name">salon.turno.calendar</field>
        <field name="model">salon.turno</field>
        <field name="arch" type="xml">
            <calendar string="Turnos" date_start="fecha_hora" date_stop="fecha_fin" color="trabajadora" mode="week">
                <field name="clienta"/>
                <field name="trabajadora"/>
                <field name="servicio"/>
                <field name="estado"/>
            </calendar>
        </field>
    </record>

    <!-- Vista de Búsqueda -->
    <record id="salon_turno_view_search" model="ir.ui.view">
        <field name="name">salon.turno.search</field>
        <field name="model">salon.turno</field>
        <field name="arch" type="xml">
            <search string="Buscar Turnos">
                <field name="clienta"/>
                <field name="telefono"/>
                <field name="servicio"/>
                <field name="estado"/>
                <filter name="filter_pendiente_pago" string="Pendiente de Pago" domain="[('estado', '=', 'pendiente_pago')]"/>
                <filter name="filter_confirmado" string="Confirmado" domain="[('estado', '=', 'confirmado')]"/>
                <filter name="filter_completado" string="Completado" domain="[('estado', '=', 'completado')]"/>
                <filter name="filter_cancelado" string="Cancelado" domain="[('estado', '=', 'cancelado')]"/>
                <separator/>
                <filter name="filter_leraysi" string="Leraysi" domain="[('trabajadora', '=', 'leraysi')]"/>
                <filter name="filter_companera" string="Compañera" domain="[('trabajadora', '=', 'companera')]"/>
                <separator/>
                <filter name="group_estado" string="Estado" context="{'group_by': 'estado'}"/>
                <filter name="group_trabajadora" string="Trabajadora" context="{'group_by': 'trabajadora'}"/>
                <filter name="group_servicio" string="Servicio" context="{'group_by': 'servicio'}"/>
                <filter name="group_fecha" string="Fecha" context="{'group_by': 'fecha_hora:day'}"/>
            </search>
        </field>
    </record>

    <!-- Vista Kanban -->
    <record id="salon_turno_view_kanban" model="ir.ui.view">
        <field name="name">salon.turno.kanban</field>
        <field name="model">salon.turno</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trabajadora" class="o_kanban_small_column">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between mb-1">
                            <strong t-out="record.clienta.value"/>
                            <field name="estado" widget="badge"
                                decoration-danger="estado == 'cancelado'"
                                decoration-success="estado == 'confirmado'"
                                decoration-info="estado == 'completado'"
                                decoration-warning="estado == 'pendiente_pago'"/>
                        </div>
                        <div class="text-muted small mb-1">
                            <field name="fecha_hora" widget="datetime"/>
                        </div>
                        <div class="mb-1">
                            <field name="servicio"/>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>
                                <i class="fa fa-clock-o"/> <field name="duracion"/>h
                            </span>
                            <strong class="text-success">
                                $<field name="precio"/>
                            </strong>
                        </div>
                        <div t-if="record.sena_pagada.raw_value" class="text-success small mt-1">
                            <i class="fa fa-check"/> Seña pagada
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción del Menú -->
    <record id="salon_turno_action" model="ir.actions.act_window">
        <field name="name">Turnos</field>
        <field name="res_model">salon.turno</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="search_view_id" ref="salon_turno_view_search"/>
        <field name="context">{'search_default_filter_hoy': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear primer turno
            </p>
            <p>
                Gestiona los turnos del salón de belleza con integración de Mercado Pago.
            </p>
        </field>
    </record>

    <!-- Menú Principal -->
    <menuitem id="salon_turnos_menu_root" name="Salón Turnos" sequence="10" web_icon="salon_turnos,static/description/icon.png"/>

    <!-- Submenú -->
    <menuitem id="salon_turnos_menu_turnos" name="Turnos" parent="salon_turnos_menu_root" action="salon_turno_action" sequence="10"/>

</odoo>
