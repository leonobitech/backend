<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción de reporte para generar PDF de recibo de pago -->
    <record id="action_report_recibo_pago" model="ir.actions.report">
        <field name="name">Recibo de Pago - Seña</field>
        <field name="model">salon.turno</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">salon_turnos.report_recibo_pago_template</field>
        <field name="report_file">salon_turnos.report_recibo_pago_template</field>
        <field name="print_report_name">'Recibo_Pago_%s_%s' % (object.clienta.replace(' ', '_'), object.id)</field>
        <field name="binding_model_id" ref="model_salon_turno"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
