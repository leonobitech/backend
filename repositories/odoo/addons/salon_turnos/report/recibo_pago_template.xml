<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_recibo_pago_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header con logo y título -->
                        <div style="text-align: center; margin-bottom: 30px;">
                            <h1 style="color: #875A7B; margin-bottom: 5px; font-size: 28px;">
                                Estilos Leraysi
                            </h1>
                            <p style="color: #666; font-size: 14px; margin: 0;">
                                Salón de Belleza - Buenos Aires, Argentina
                            </p>
                        </div>

                        <!-- Título del recibo -->
                        <div style="background: linear-gradient(135deg, #875A7B 0%, #6B4F6B 100%);
                                    color: white;
                                    padding: 15px 20px;
                                    border-radius: 8px;
                                    margin-bottom: 25px;
                                    text-align: center;">
                            <h2 style="margin: 0; font-size: 22px;">RECIBO DE PAGO - SEÑA</h2>
                            <p style="margin: 5px 0 0 0; font-size: 14px; opacity: 0.9;">
                                Comprobante de reserva de turno
                            </p>
                        </div>

                        <!-- Info del recibo -->
                        <div style="display: flex; justify-content: space-between; margin-bottom: 25px;">
                            <div>
                                <p style="margin: 0; color: #666; font-size: 12px;">Fecha de emisión</p>
                                <p style="margin: 0; font-weight: bold;">
                                    <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                </p>
                            </div>
                            <div style="text-align: right;">
                                <p style="margin: 0; color: #666; font-size: 12px;">N° de Turno</p>
                                <p style="margin: 0; font-weight: bold; font-size: 18px; color: #875A7B;">
                                    #<t t-esc="o.id"/>
                                </p>
                            </div>
                        </div>

                        <!-- Datos de la clienta -->
                        <div style="background-color: #f8f9fa;
                                    padding: 20px;
                                    border-radius: 8px;
                                    margin-bottom: 20px;
                                    border-left: 4px solid #875A7B;">
                            <h3 style="margin: 0 0 15px 0; color: #875A7B; font-size: 16px;">
                                DATOS DE LA CLIENTA
                            </h3>
                            <table style="width: 100%;">
                                <tr>
                                    <td style="padding: 5px 0; width: 120px; color: #666;">Nombre:</td>
                                    <td style="padding: 5px 0; font-weight: bold;">
                                        <t t-esc="o.clienta"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 5px 0; color: #666;">Teléfono:</td>
                                    <td style="padding: 5px 0;">
                                        <t t-esc="o.telefono"/>
                                    </td>
                                </tr>
                                <t t-if="o.email">
                                    <tr>
                                        <td style="padding: 5px 0; color: #666;">Email:</td>
                                        <td style="padding: 5px 0;">
                                            <t t-esc="o.email"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>

                        <!-- Datos del servicio -->
                        <div style="background-color: #f8f9fa;
                                    padding: 20px;
                                    border-radius: 8px;
                                    margin-bottom: 20px;
                                    border-left: 4px solid #17a2b8;">
                            <h3 style="margin: 0 0 15px 0; color: #17a2b8; font-size: 16px;">
                                DETALLE DEL SERVICIO
                            </h3>
                            <table style="width: 100%;">
                                <tr>
                                    <td style="padding: 5px 0; width: 120px; color: #666;">Servicio:</td>
                                    <td style="padding: 5px 0; font-weight: bold; text-transform: capitalize;">
                                        <t t-esc="dict(o._fields['servicio'].selection).get(o.servicio)"/>
                                    </td>
                                </tr>
                                <t t-if="o.servicio_detalle">
                                    <tr>
                                        <td style="padding: 5px 0; color: #666;">Detalle:</td>
                                        <td style="padding: 5px 0;">
                                            <t t-esc="o.servicio_detalle"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td style="padding: 5px 0; color: #666;">Fecha:</td>
                                    <td style="padding: 5px 0; font-weight: bold;">
                                        <t t-esc="o.fecha_hora.strftime('%A %d de %B, %Y')" />
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 5px 0; color: #666;">Hora:</td>
                                    <td style="padding: 5px 0; font-weight: bold;">
                                        <t t-esc="o.fecha_hora.strftime('%H:%M')"/> hs
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 5px 0; color: #666;">Duración:</td>
                                    <td style="padding: 5px 0;">
                                        <t t-esc="o.duracion"/> hora(s)
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Detalle del pago -->
                        <div style="background-color: #d4edda;
                                    padding: 20px;
                                    border-radius: 8px;
                                    margin-bottom: 20px;
                                    border: 2px solid #28a745;">
                            <h3 style="margin: 0 0 15px 0; color: #28a745; font-size: 16px;">
                                DETALLE DEL PAGO
                            </h3>
                            <table style="width: 100%;">
                                <tr>
                                    <td style="padding: 8px 0; color: #666;">Precio total del servicio:</td>
                                    <td style="padding: 8px 0; text-align: right;">
                                        $ <t t-esc="'{:,.2f}'.format(o.precio).replace(',', '.')"/>
                                    </td>
                                </tr>
                                <tr style="border-top: 1px dashed #ccc;">
                                    <td style="padding: 8px 0; color: #666;">Seña (30%):</td>
                                    <td style="padding: 8px 0; text-align: right; font-weight: bold; color: #28a745; font-size: 18px;">
                                        $ <t t-esc="'{:,.2f}'.format(o.sena).replace(',', '.')"/>
                                    </td>
                                </tr>
                                <tr style="border-top: 1px dashed #ccc;">
                                    <td style="padding: 8px 0; color: #666;">Monto restante a pagar:</td>
                                    <td style="padding: 8px 0; text-align: right;">
                                        $ <t t-esc="'{:,.2f}'.format(o.monto_restante).replace(',', '.')"/>
                                    </td>
                                </tr>
                            </table>

                            <t t-if="o.mp_payment_id">
                                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #28a745;">
                                    <p style="margin: 0; color: #666; font-size: 12px;">
                                        ID de Pago Mercado Pago:
                                    </p>
                                    <p style="margin: 5px 0 0 0; font-family: monospace; font-size: 14px;">
                                        <t t-esc="o.mp_payment_id"/>
                                    </p>
                                </div>
                            </t>
                        </div>

                        <!-- Estado del turno -->
                        <div style="text-align: center; margin: 30px 0;">
                            <span style="background-color: #28a745;
                                         color: white;
                                         padding: 10px 30px;
                                         border-radius: 20px;
                                         font-weight: bold;
                                         font-size: 16px;">
                                TURNO CONFIRMADO
                            </span>
                        </div>

                        <!-- Información importante -->
                        <div style="background-color: #fff3cd;
                                    padding: 15px;
                                    border-radius: 8px;
                                    margin-bottom: 20px;
                                    border: 1px solid #ffc107;">
                            <h4 style="margin: 0 0 10px 0; color: #856404;">
                                Información importante:
                            </h4>
                            <ul style="margin: 0; padding-left: 20px; color: #856404; font-size: 13px;">
                                <li>El monto restante debe abonarse el día del turno.</li>
                                <li>En caso de cancelación, avisar con 24hs de anticipación.</li>
                                <li>La seña no es reembolsable en caso de no asistencia.</li>
                            </ul>
                        </div>

                        <!-- Footer con datos del salón -->
                        <div style="text-align: center;
                                    margin-top: 30px;
                                    padding-top: 20px;
                                    border-top: 2px solid #875A7B;">
                            <p style="margin: 0; font-weight: bold; color: #875A7B;">
                                Estilos Leraysi - Salón de Belleza
                            </p>
                            <p style="margin: 5px 0; color: #666; font-size: 13px;">
                                Buenos Aires, Argentina
                            </p>
                            <p style="margin: 5px 0; color: #666; font-size: 13px;">
                                WhatsApp: +54 9 11 XXXX-XXXX
                            </p>
                            <p style="margin: 15px 0 0 0; color: #999; font-size: 11px;">
                                Documento generado automáticamente por el sistema de gestión de turnos
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
