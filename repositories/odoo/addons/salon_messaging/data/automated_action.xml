<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Default config parameters for salon_messaging.
            Set these via Settings > Technical > Parameters > System Parameters:
            - salon_messaging.api_key: API key for n8n to authenticate requests
            - salon_messaging.n8n_webhook_url: n8n webhook URL for manual reply forwarding
        -->
        <record id="config_param_api_key" model="ir.config_parameter">
            <field name="key">salon_messaging.api_key</field>
            <field name="value"></field>
        </record>
        <record id="config_param_n8n_webhook_url" model="ir.config_parameter">
            <field name="key">salon_messaging.n8n_webhook_url</field>
            <field name="value"></field>
        </record>
    </data>
</odoo>
