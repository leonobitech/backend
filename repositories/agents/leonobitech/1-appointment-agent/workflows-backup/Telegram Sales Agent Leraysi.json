      "parameters": {
        "jsCode": "const msg = $input.first().json.body.message;\nconst chat = msg.chat;\nconst from = msg.from;\nconst profile_base = {\n  phone_e164: String(chat.id),\n  nick_name: from.first_name || 'Unknown',\n  canal: 'telegram',\n  telegram_chat_id: String(chat.id),\n  telegram_username: from.username || '',\n  chatwoot_id: '',\n};\nconst event = {\n  message_text: msg.text || '[audio]',\n  message_id: String(msg.message_id),\n  now_iso_local: new Date().toISOString(),\n  has_voice: !!msg.voice,\n  has_photo: !!msg.photo,\n};\nreturn [{ json: { profile_base, event } }];"
      },
