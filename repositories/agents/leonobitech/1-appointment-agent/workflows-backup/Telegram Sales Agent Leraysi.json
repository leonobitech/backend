    {
      "parameters": {
        "jsCode": "const bufRaw = $input.first().json.buf_raw;\nconst currentEvent = $('Normalize Inbound').first().json.event;\n\nlet events = [];\ntry {\n  if (Array.isArray(bufRaw)) {\n    events = bufRaw.map(e => typeof e === 'string' ? JSON.parse(e) : e);\n  } else if (typeof bufRaw === 'string') {\n    try { const parsed = JSON.parse(bufRaw); events = Array.isArray(parsed) ? parsed : [parsed]; }\n    catch { events = []; }\n  }\n} catch(e) { events = []; }\n\nconst lastEvent = events.length > 0 ? events[events.length - 1] : null;\n\nif (!lastEvent || lastEvent.message_id !== currentEvent.message_id) {\n  return [{ json: { action: 'discard' } }];\n}\n\nconst concatenatedText = events.map(e => e.message_text).join(' ');\nreturn [{ json: { action: 'process', concatenated_text: concatenatedText, event_count: events.length, profile_base: $('Normalize Inbound').first().json.profile_base } }];"
      },
