# Server Configuration
SERVER__HOST=0.0.0.0
SERVER__PORT=3000
SERVER__ENVIRONMENT=development

# Database Configuration
DATABASE__URL=postgres://user:password@localhost:5432/core_v2
DATABASE__MAX_CONNECTIONS=20
DATABASE__MIN_CONNECTIONS=5

# Redis Configuration
REDIS__URL=redis://localhost:6379

# Authentication Configuration
AUTH__JWT_SECRET=your-secret-key-change-in-production
AUTH__ACCESS_TOKEN_TTL_SECONDS=900
AUTH__REFRESH_TOKEN_TTL_SECONDS=604800

# Logging
RUST_LOG=info,core_v2=debug,sqlx=warn
