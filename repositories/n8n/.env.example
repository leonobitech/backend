# Configuración de n8n para Docker
POSTGRES_USER=n8n
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=n8n


# DOMAIN_NAME and SUBDOMAIN together determine where n8n will be reachable from
# The top level domain to serve from
DOMAIN_NAME=example.com

# The subdomain to serve from
SUBDOMAIN=n8n

# Dominio y ruta base de n8n
N8N_PROTOCOL=https
N8N_HOST=n8n.example.com
WEBHOOK_URL=https://n8n.example.com/
NODE_ENV=production


# Configuración core
N8N_ENCRYPTION_KEY=keyshould_be_longer_than_32_characters
GENERIC_TIMEZONE=Europe/Berlin

# Flags recomendadas
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# Configuración de la base de datos PostgreSQL
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres_n8n
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=supersecretpassword

# Ejecuciones en modo cola
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis_n8n
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=0
QUEUE_BULL_REDIS_PREFIX=bull

# Extras
N8N_METRICS=true
QUEUE_HEALTH_CHECK_ACTIVE=true
