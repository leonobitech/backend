// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  password         String?
  name             String?
  avatar           String?
  bio              String?
  role             String   @default("user")
  verified         Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastLogin        DateTime?

  // Profile fields
  website          String?
  location         String?
  socialTwitter    String?
  socialInstagram  String?
  socialYoutube    String?
  socialGithub     String?

  sessions          Session[]
  verificationCodes VerificationCode[]
  devices           Device[]
  tokenRecords      TokenRecord[]
  securityEventLogs SecurityEventLog[]
  passkeys          Passkey[]
  podcasts          Podcast[]
  iotDevices        IotDevice[]

  // LMS
  enrollments       Enrollment[]
  graduates         Graduate[]
}

model Device {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @map("userId") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  device      String
  os          String
  browser     String
  ipAddress   String
  userAgent   String
  language    String
  timezone    String
  platform    String
  screenResolution String
  label       String

  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    Session[]
  passkeys    Passkey[]
  @@unique([userId, device, os, browser], name: "unique_device")
}

model Session {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  deviceId   String   @map("deviceId") @db.ObjectId
  device     Device   @relation(fields: [deviceId], references: [id])
  clientKey  String
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime? @default(now())

  tokens              TokenRecord[]        // ✅ tokens relacionados
  securityEventLogs   SecurityEventLog[]   // ✅ logs de seguridad

  @@index([userId])
  @@unique([userId, deviceId, clientKey], name: "unique_session_fingerprint")
}
model TokenRecord {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  jti        String   @unique
  token      String
  publicKey  String
  type       TokenType
  encrypted  Boolean  @default(true)
  issuedAt   DateTime @default(now())
  expiresAt  DateTime
  revoked    Boolean  @default(false)

  sessionId  String   @map("sessionId") @db.ObjectId
  session    Session  @relation(fields: [sessionId], references: [id]) // ✅ limpia

  userId     String   @map("userId") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
}

enum TokenType {
  ACCESS
  REFRESH
}

model VerificationCode {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  type       String
  hashedCode String
  requestId  String   @unique
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model SecurityEventLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  sessionId  String   @map("sessionId") @db.ObjectId
  type       String
  ipAddress  String
  browser    String
  os         String
  path       String
  method     String
  host       String
  details    String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id]) // ✅ también limpia

  @@index([userId])
  @@index([sessionId])
}

// 🚨 Log de ataques e intentos de acceso no autorizados (sin requerir userId/sessionId)
model AttackLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // Tipo de ataque: "missing_cookies", "session_mismatch", "expired_meta", "invalid_token"
  severity    String   @default("medium") // low, medium, high, critical
  ipAddress   String
  userAgent   String
  path        String
  method      String
  host        String
  details     String?  // JSON con detalles adicionales
  blocked     Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Opcional: si logramos identificar al usuario/sesión del token robado
  attemptedUserId    String?
  attemptedSessionId String?

  @@index([ipAddress])
  @@index([type])
  @@index([createdAt])
  @@index([severity])
}

model Passkey {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @map("userId") @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  credentialId    String   @unique // WebAuthn credential ID (base64url)
  publicKey       String   // Public key (base64url)
  counter         Int      @default(0) // Signature counter for replay protection

  deviceId        String?  @map("deviceId") @db.ObjectId
  device          Device?  @relation(fields: [deviceId], references: [id])

  name            String?  // Friendly name (e.g., "MacBook Pro", "iPhone 13")
  transports      String[] // Authenticator transports (usb, nfc, ble, internal)

  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())

  @@index([userId])
}

model Podcast {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  videoUrl      String   // Baserow URL to MP4 file
  thumbnailUrl  String?  // Thumbnail image URL
  duration      Int      // Duration in seconds
  width       Int?     // Video width in pixels
  height      Int?     // Video height in pixels
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   String   @map("createdBy") @db.ObjectId
  user        User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([publishedAt])
}

// =============================================================================
// IoT Device Models - ESP32 and other embedded devices
// =============================================================================

model IotDevice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @unique // Unique device identifier (set during provisioning)
  apiKey          String   // API key for device authentication (hashed)
  name            String?  // User-friendly name
  type            String?  // Device type (sensor, actuator, gateway, etc.)
  firmwareVersion String?  // Current firmware version
  metadata        Json?    // Additional device metadata

  // Device status
  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime?

  // Light control state
  lightIntensity  Int      @default(0)      // 0-100 current intensity
  lightTemperature Int     @default(50)     // 0-100 color temperature (0=warm, 100=cool)
  lightMode       String   @default("manual") // "manual" or "auto"
  activeScheduleId String? @map("activeScheduleId") @db.ObjectId

  // Owner (admin who registered the device)
  ownerId         String?  @map("ownerId") @db.ObjectId
  owner           User?    @relation(fields: [ownerId], references: [id])

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  telemetry       IotTelemetry[]
  commands        IotCommand[]
  schedules       LightSchedule[]

  @@index([ownerId])
  @@index([isOnline])
  @@index([type])
}

model IotTelemetry {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @map("deviceId") @db.ObjectId
  device          IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Telemetry data
  freeHeap        Int      // Free heap memory in bytes
  wifiRssi        Int      // WiFi signal strength (RSSI)
  uptimeSecs      Int      // Uptime in seconds
  sensors         Json?    // Custom sensor data (JSON)

  createdAt       DateTime @default(now())

  @@index([deviceId])
  @@index([createdAt])
}

model IotCommand {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @map("deviceId") @db.ObjectId
  device          IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Command details
  action          String   // Command action (e.g., "led_on", "restart", "get_status")
  params          Json?    // Command parameters

  // Execution status
  status          IotCommandStatus @default(PENDING)
  result          String?  // Result message from device

  // Timestamps
  createdAt       DateTime @default(now())
  executedAt      DateTime?
  acknowledgedAt  DateTime?

  // Who sent the command
  sentBy          String?  @map("sentBy") @db.ObjectId

  @@index([deviceId])
  @@index([status])
  @@index([createdAt])
}

enum IotCommandStatus {
  PENDING
  SENT
  EXECUTED
  FAILED
  EXPIRED
}

// =============================================================================
// Light Schedule Model - For automated light control
// =============================================================================

model LightSchedule {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   // Schedule name (e.g., "Vegetative Cycle", "Flowering Cycle")
  description     String?  // Optional description

  // Device relation
  deviceId        String   @map("deviceId") @db.ObjectId
  device          IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Schedule state
  isActive        Boolean  @default(false) // Only one schedule per device should be active

  // Schedule points (JSON array of SchedulePoint)
  // Each point: { hour: 0-23, minute: 0-59, intensity: 0-100, temperature: 0-100 }
  points          Json     // SchedulePoint[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deviceId])
  @@index([isActive])
}

// =============================================================================
// LMS Models - Learning Management System
// =============================================================================

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REFUNDED
}

model Course {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String       @unique
  description   String
  thumbnailUrl  String?
  price         Float
  currency      String       @default("USD")
  status        CourseStatus  @default(DRAFT)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  modules       Module[]
  enrollments   Enrollment[]
  assessments   Assessment[]
  graduates     Graduate[]

  @@index([status])
}

model Module {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId   String   @map("courseId") @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons   Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String     @map("moduleId") @db.ObjectId
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?
  videoUrl    String?
  duration    Int?       // Duration in seconds
  order       Int
  type        LessonType @default(VIDEO)
  content     String?    // Rich text content for TEXT type lessons

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  progress    Progress[]

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model Enrollment {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  userId          String           @map("userId") @db.ObjectId
  user            User             @relation(fields: [userId], references: [id])
  courseId         String           @map("courseId") @db.ObjectId
  course          Course           @relation(fields: [courseId], references: [id])
  status          EnrollmentStatus @default(ACTIVE)
  stripePaymentId String?
  stripeSessionId String?
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?

  progress           Progress[]
  assessmentAttempts  AssessmentAttempt[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Progress {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId String     @map("enrollmentId") @db.ObjectId
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String     @map("lessonId") @db.ObjectId
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed    Boolean    @default(false)
  completedAt  DateTime?

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
}

model Assessment {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId      String   @map("courseId") @db.ObjectId
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  questions    Json     // Array of question objects
  passingScore Int      @default(70)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attempts     AssessmentAttempt[]

  @@index([courseId])
}

model AssessmentAttempt {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId String     @map("enrollmentId") @db.ObjectId
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  assessmentId String     @map("assessmentId") @db.ObjectId
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers      Json
  score        Int
  passed       Boolean
  completedAt  DateTime   @default(now())

  @@index([enrollmentId])
  @@index([assessmentId])
}

model Graduate {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @map("userId") @db.ObjectId
  user                User     @relation(fields: [userId], references: [id])
  courseId             String   @map("courseId") @db.ObjectId
  course              Course   @relation(fields: [courseId], references: [id])
  slug                String   @unique
  projectTitle        String
  projectDescription  String
  projectDemoUrl      String?
  projectScreenshots  String[]
  verified            Boolean  @default(false)
  publishedAt         DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([verified])
}