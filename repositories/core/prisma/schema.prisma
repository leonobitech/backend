// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  password         String
  name             String?
  avatar           String?
  bio              String?
  role             String   @default("user")
  verified         Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastLogin        DateTime?

  // Profile fields
  website          String?
  location         String?
  socialTwitter    String?
  socialInstagram  String?
  socialYoutube    String?
  socialGithub     String?

  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  twoFactorAttempts Int     @default(0)

  sessions          Session[]
  verificationCodes VerificationCode[]
  devices           Device[]
  tokenRecords      TokenRecord[]
  securityEventLogs SecurityEventLog[]
  passkeys          Passkey[]
  podcasts          Podcast[]
  iotDevices        IotDevice[]
}

model Device {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @map("userId") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  device      String
  os          String
  browser     String
  ipAddress   String
  userAgent   String
  language    String
  timezone    String
  platform    String
  screenResolution String
  label       String

  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    Session[]
  passkeys    Passkey[]
  @@unique([userId, device, os, browser], name: "unique_device")
}

model Session {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  deviceId   String   @map("deviceId") @db.ObjectId
  device     Device   @relation(fields: [deviceId], references: [id])
  clientKey  String
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime? @default(now())

  tokens              TokenRecord[]        // ✅ tokens relacionados
  securityEventLogs   SecurityEventLog[]   // ✅ logs de seguridad

  @@index([userId])
  @@unique([userId, deviceId, clientKey], name: "unique_session_fingerprint")
}
model TokenRecord {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  jti        String   @unique
  token      String
  publicKey  String
  type       TokenType
  encrypted  Boolean  @default(true)
  issuedAt   DateTime @default(now())
  expiresAt  DateTime
  revoked    Boolean  @default(false)

  sessionId  String   @map("sessionId") @db.ObjectId
  session    Session  @relation(fields: [sessionId], references: [id]) // ✅ limpia

  userId     String   @map("userId") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
}

enum TokenType {
  ACCESS
  REFRESH
}

model VerificationCode {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  type       String
  hashedCode String
  requestId  String   @unique
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model SecurityEventLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("userId") @db.ObjectId
  sessionId  String   @map("sessionId") @db.ObjectId
  type       String
  ipAddress  String
  browser    String
  os         String
  path       String
  method     String
  host       String
  details    String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id]) // ✅ también limpia

  @@index([userId])
  @@index([sessionId])
}

model Passkey {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @map("userId") @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  credentialId    String   @unique // WebAuthn credential ID (base64url)
  publicKey       String   // Public key (base64url)
  counter         Int      @default(0) // Signature counter for replay protection

  deviceId        String?  @map("deviceId") @db.ObjectId
  device          Device?  @relation(fields: [deviceId], references: [id])

  name            String?  // Friendly name (e.g., "MacBook Pro", "iPhone 13")
  transports      String[] // Authenticator transports (usb, nfc, ble, internal)

  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())

  @@index([userId])
}

model Podcast {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  videoUrl    String   // Baserow URL to MP4 file
  duration    Int      // Duration in seconds
  width       Int?     // Video width in pixels
  height      Int?     // Video height in pixels
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   String   @map("createdBy") @db.ObjectId
  user        User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([publishedAt])
}

// =============================================================================
// IoT Device Models - ESP32 and other embedded devices
// =============================================================================

model IotDevice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @unique // Unique device identifier (set during provisioning)
  apiKey          String   // API key for device authentication (hashed)
  name            String?  // User-friendly name
  firmwareVersion String?  // Current firmware version

  // Device status
  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime?

  // Owner (admin who registered the device)
  ownerId         String?  @map("ownerId") @db.ObjectId
  owner           User?    @relation(fields: [ownerId], references: [id])

  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  telemetry       IotTelemetry[]
  commands        IotCommand[]

  @@index([ownerId])
  @@index([isOnline])
}

model IotTelemetry {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @map("deviceId") @db.ObjectId
  device          IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Telemetry data
  freeHeap        Int      // Free heap memory in bytes
  wifiRssi        Int      // WiFi signal strength (RSSI)
  uptimeSecs      Int      // Uptime in seconds
  sensors         Json?    // Custom sensor data (JSON)

  createdAt       DateTime @default(now())

  @@index([deviceId])
  @@index([createdAt])
}

model IotCommand {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId        String   @map("deviceId") @db.ObjectId
  device          IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Command details
  action          String   // Command action (e.g., "led_on", "restart", "get_status")
  params          Json?    // Command parameters

  // Execution status
  status          IotCommandStatus @default(PENDING)
  result          String?  // Result message from device

  // Timestamps
  createdAt       DateTime @default(now())
  executedAt      DateTime?
  acknowledgedAt  DateTime?

  // Who sent the command
  sentBy          String?  @map("sentBy") @db.ObjectId

  @@index([deviceId])
  @@index([status])
  @@index([createdAt])
}

enum IotCommandStatus {
  PENDING
  SENT
  EXECUTED
  FAILED
  EXPIRED
}