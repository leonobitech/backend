# Server Configuration
NODE_ENV=production
PORT=8100
PUBLIC_URL=https://odoo-mcp.leonobitech.com

# OAuth 2.1 Configuration
CLIENT_ID=odoo-mcp
CLIENT_SECRET=super-secret-change-me-in-production
REDIRECT_URI=https://claude.ai/api/mcp/auth/callback
SCOPES=odoo:read odoo:write

# JWT Configuration
JWKS_KID=odoo-mcp-key-1
JWT_ISSUER=https://odoo-mcp.leonobitech.com
JWT_AUDIENCE=odoo-mcp
ACCESS_TOKEN_TTL=300
AUTH_CODE_TTL=180
REFRESH_TOKEN_TTL=604800

# Database (MongoDB)
DATABASE_URL=mongodb://user:password@localhost:27017/odoo_mcp?authSource=admin

# Redis (Token & Session Storage)
REDIS_HOST=redis_core
REDIS_PORT=6379
REDIS_PASSWORD=supersecretpassword123
REDIS_DB=1

# Session Configuration
SESSION_TTL=604800
SESSION_COOKIE_NAME=odoo_mcp_session
SESSION_COOKIE_SECRET=change-this-to-random-64-char-secret

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# CORS
CORS_ORIGINS=https://claude.ai,https://app.claude.ai,https://desktop.claude.ai,https://odoo-mcp.leonobitech.com,https://leonobitech.com

# Logging
LOG_LEVEL=info

# Encryption (for storing Odoo credentials in DB)
ENCRYPTION_KEY=change-this-to-random-32-byte-hex-key

# Service Account (for internal n8n access)
SERVICE_TOKEN=change-this-to-random-64-char-secret
ODOO_SERVICE_URL=http://odoo:8069
ODOO_SERVICE_DB=leonobitech
ODOO_SERVICE_USER=admin@leonobitech.com
ODOO_SERVICE_API_KEY=your-odoo-api-key-here
