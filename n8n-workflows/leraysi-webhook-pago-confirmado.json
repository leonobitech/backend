    {
      "parameters": {
        "functionCode": "// Extraer datos del pago de MercadoPago\nconst payment = $input.first().json;\n\n// external_reference tiene formato: \"turno_{turno_id}_lead_{lead_id}\"\n// Ejemplo: \"turno_123_lead_456\"\nconst externalRef = payment.external_reference || '';\n\n// Parse external_reference\nlet turnoId = null;\nlet leadId = null;\n\nconst turnoMatch = externalRef.match(/turno_(\\d+)/);\nconst leadMatch = externalRef.match(/lead_(\\d+)/);\n\nif (turnoMatch) turnoId = parseInt(turnoMatch[1]);\nif (leadMatch) leadId = parseInt(leadMatch[1]);\n\nif (!turnoId) {\n  throw new Error(`No se pudo extraer turno_id de external_reference: ${externalRef}`);\n}\n\nreturn {\n  json: {\n    mp_payment_id: payment.id.toString(),\n    turno_id: turnoId,\n    lead_id: leadId,\n    amount: payment.transaction_amount,\n    currency: payment.currency_id,\n    status: payment.status,\n    status_detail: payment.status_detail,\n    payer_email: payment.payer?.email || null,\n    payer_name: payment.payer?.first_name || null,\n    external_reference: externalRef,\n    date_approved: payment.date_approved\n  }\n};"
      },
      "name": "Parse Payment Data",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1050, 100],
      "notesInFlow": true,
      "notes": "Parsea external_reference para obtener turno_id y lead_id.\nFormato esperado: turno_{id}_lead_{id}"
    },
    {
      "parameters": {
        "operation": "search",
        "tableId": "={{ $env.BASEROW_TURNOS_LERAYSI_TABLE_ID }}",
        "searchField": "odoo_turno_id",
