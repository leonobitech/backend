      },
      "name": "Baserow: Get Turno",
      "type": "n8n-nodes-base.baserow",
      "typeVersion": 1,
      "position": [1250, 100],
      "credentials": {
        "baserowApi": {
          "id": "baserow_credentials",
          "name": "Baserow API"
        }
      },
      "notesInFlow": true,
      "notes": "Busca el turno en Baserow por odoo_turno_id"
    },
    {
      "parameters": {
        "functionCode": "// Combinar datos del pago con datos del turno de Baserow\nconst payment = $('Parse Payment Data').first().json;\nconst turnoRows = $input.all();\n\nif (turnoRows.length === 0) {\n  throw new Error(`Turno no encontrado en Baserow: ${payment.turno_id}`);\n}\n\nconst turno = turnoRows[0].json;\n\n// Obtener lead_id de Baserow si no viene en external_reference\nconst leadId = payment.lead_id || turno.lead_row_id;\n\nif (!leadId) {\n  throw new Error('No se pudo determinar lead_id');\n}\n\nreturn {\n  json: {\n    // Datos del pago MP\n    mp_payment_id: payment.mp_payment_id,\n    amount: payment.amount,\n    payer_email: payment.payer_email,\n    date_approved: payment.date_approved,\n    \n    // IDs\n    turno_id: payment.turno_id,\n    lead_id: leadId,\n    turno_row_id: turno.id,\n    \n    // Datos del turno de Baserow\n    conversation_id: turno.conversation_id || null,\n    clienta: turno.clienta,\n    telefono: turno.telefono,\n    email: turno.email || payment.payer_email\n  }\n};"
      },
      "name": "Merge Payment + Turno",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1450, 100]
    },
